---
interface Props {
  title: string;
  type?: 'info' | 'warning' | 'success';
  body: string;
}
const { title, type = 'warning', body } = Astro.props;

const colors = {
  warning: { bg: '#FAEEDA', border: '#FAC775', text: '#633806', title: '#4A1B0C' },
  info:    { bg: '#E6F1FB', border: '#378ADD', text: '#042C53', title: '#042C53' },
  success: { bg: '#E1F5EE', border: '#1D9E75', text: '#085041', title: '#04342C' },
};
const c = colors[type];
---
<div class="notice" style={`background:${c.bg};border-left-color:${c.border};`}>
  <div class="notice-icon">{type === 'warning' ? '📅' : type === 'success' ? '✅' : 'ℹ️'}</div>
  <div>
    <div class="notice-title" style={`color:${c.title}`}>{title}</div>
    <div class="notice-body" style={`color:${c.text}`} set:html={body} />
  </div>
</div>

<style>
  .notice {
    border: 1px solid rgba(0,0,0,0.1);
    border-left: 4px solid;
    border-radius: 10px; padding: 1rem 1.25rem;
    display: flex; gap: 12px; align-items: flex-start;
    margin-top: 1.75rem;
  }
  .notice-icon { font-size: 16px; flex-shrink: 0; margin-top: 2px; }
  .notice-title { font-size: 13px; font-weight: 500; margin-bottom: 4px; }
  .notice-body { font-size: 12.5px; line-height: 1.6; }
  .notice-body strong { font-weight: 500; }
</style>
